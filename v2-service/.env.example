# Переменные для docker-compose (compose читает v2-service/.env автоматически).
# Скопируй в .env и задай SECRET. Остальное имеет дев-дефолты в compose.
#
#   cp .env.example .env   &&   отредактируй SECRET

# ОБЯЗАТЕЛЬНО. Секрет для подписи cookie/JWT (fastapi-users), >=32 байта.
# Сгенерировать:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET=

# Учётные данные Postgres (дефолты ontol/ontol/ontol).
POSTGRES_USER=ontol
POSTGRES_PASSWORD=ontol
POSTGRES_DB=ontol

# Разрешённые источники CORS (JSON-массив). Дефолт — фронт на Vite.
CORS_ORIGINS=["http://localhost:5173"]
